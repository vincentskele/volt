# Discord API token from the Discord Developer Portal
TOKEN= (api token)
CLIENT_ID= (app id)
DISCORD_CLIENT_SECRET=
GUILD_ID= (discord server id)
#Used for retrieving info from Discord for WebApp
INFO_TOKEN=

# Customizable points settings
POINTS_NAME=           # The name of your points (e.g., bolts, gems, coins)
POINTS_SYMBOL=         # The symbol of your points (e.g., ⚡, 💎, 🪙)

#Automatic Message rewards
MESSAGE_REWARD_CHANNELS=
MESSAGE_REWARD_AMOUNT=
MESSAGE_REWARD_LIMIT=
REACTION_REWARD_CHANNEL=  # Channel where reaction rewards are given
REACTION_REWARD_AMOUNT=                  # Amount given for reacting once per day
FIRST_MESSAGE_BONUS_CHANNEL=  # when blank defaults to all channels
FIRST_MESSAGE_BONUS=
# Customizable help command
HELP_COMMAND=            # The command name for the help message (e.g., pizzahelp)

# Additional bot settings
PREFIX=$                 # Command prefix for the bot (e.g., $, !, ?)
BOT_NAME=
ALLOWED_ROLES=    # Leave blank to allow all roles - use role IDs not names
# Web App
SERVER_HOST=0.0.0.0
SERVER_PORT=3003
VOLT_PUBLIC_URL=http://192.168.1.42:3003
WEBUI_GIVEAWAY_CHANNELID=
WEBUI_RAFFLE_CHANNELID=                                                                         
SUBMISSION_CHANNEL_ID= #use this if you want to aggregate all submissions to one channel
QUEST_SUBMISSION_CHANNEL_ID= #use this if you want individual channels for quests
WEB_ADMIN_EDITS_CHANNEL_ID= #use this if you want to log admin edits to an independent channel
ITEM_REDEMPTION_CHANNEL_ID= #use this if you want to log item redemptions to an independent channel
BASE_URL=http://192.168.1.42:3003

# Optional consensus-layer settings for external volt-node verifiers.
# Use the same per-operator VOLT_NODE_AUTH_KEY that the verifier node uses for register/heartbeat/report/status/export access.
VOLT_NODE_AUTH_KEY=
VOLT_NETWORK_NODE_URLS=
VOLT_NETWORK_CANONICAL_ID=volt-primary
VOLT_NETWORK_CANONICAL_NAME=Volt Primary

# Voice channel rewards
VOICE_REWARD_CHANNEL_ID=YOUR_CHANNEL_ID
VOICE_REWARD_AMOUNT=40
VOICE_REWARD_DAY=3                  # Example: Wednesday
VOICE_REWARD_HOUR=18                # 6PM in 24-hr format
VOICE_REWARD_DURATION=60           # in minutes
VOICE_REWARD_MINUTES_REQUIRED=15

# Trivia Rewards
TRIVIA_CHANNEL_ID=your_channel_id_here
TRIVIA_QUESTIONS_PER_DAY=5
TRIVIA_REWARD_AMOUNT=50
